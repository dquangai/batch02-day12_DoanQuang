# Copy thành .env và điền giá trị thật.
# Không commit file .env lên Git.

# Server
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=false

# App
APP_NAME=Production AI Agent
APP_VERSION=1.0.0

# LLM
OPENAI_API_KEY=
LLM_MODEL=mock-llm

# Security - bắt buộc thay trong production
AGENT_API_KEY=dev-key-change-me

# Rate & Budget
RATE_LIMIT_PER_MINUTE=10
RATE_LIMIT_WINDOW_SECONDS=60
MONTHLY_BUDGET_USD=10.0
INPUT_PRICE_PER_1K_TOKENS=0.00015
OUTPUT_PRICE_PER_1K_TOKENS=0.0006

# Storage
REDIS_URL=redis://localhost:6379/0
REQUIRE_REDIS=false
HISTORY_TTL_SECONDS=2592000
MAX_HISTORY_MESSAGES=20

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# Local load balancer port for docker compose
NGINX_PORT=80
